# aura-mystic-admin — environment variables
# Copy this file to `.env.local` and fill in real values. Do NOT commit `.env.local`.

# Base URL of the fared-backend REST API that this admin panel talks to.
# Every data call (auth, products, orders, media uploads, etc.) is sent to this origin.
# Without a reachable backend at this URL, login fails and the panel cannot load data.
# Example (local backend): http://localhost:4000
# Example (Render backend): https://fared-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:4000